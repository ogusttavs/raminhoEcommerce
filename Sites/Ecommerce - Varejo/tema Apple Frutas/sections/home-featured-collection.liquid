{%- assign featured_collection = section.settings.collection -%}
{%- if featured_collection == blank -%}
  {%- assign featured_collection = collections['frutas'] -%}
{%- endif -%}

<section id="products" class="section-block section-block--tight">
  <div class="page-width">
    <div class="section-heading section-heading--split reveal">
      <div>
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div>
        <p>{{ section.settings.text }}</p>
        {%- if featured_collection != blank -%}
          <a class="text-link" href="{{ featured_collection.url }}">Ver colecao completa</a>
        {%- endif -%}
      </div>
    </div>

    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <div class="product-grid product-grid--single-row">
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', card_product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="empty-state reveal">
        <h3>Conecte uma colecao para ver a vitrine premium.</h3>
        <p>Assim que a colecao for definida no editor do tema, os produtos aparecem aqui com o novo visual.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Colecao em destaque",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Colecao"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curadoria do dia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Produtos que seguram o visual e a margem."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Cards amplos, fotografias grandes e informacao certa para transformar fruta em desejo de compra."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Produtos exibidos",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Colecao em destaque"
    }
  ]
}
{% endschema %}
