{%- liquid
  assign home_link = routes.root_url | append: '#home'
  assign about_link = routes.root_url | append: '#about'
  assign catalog_link = routes.collections_url | append: '/all'
  assign retail_link = routes.root_url | append: '#retail'
  assign wholesale_link = settings.wholesale_url | default: 'https://raminhoimportadora.com.br/'
  assign contact_link = settings.whatsapp_url
  if contact_link == blank
    assign contact_link = routes.root_url | append: '#contact'
  endif
  assign partners_link = routes.root_url | append: '#contact'
  if settings.wholesale_url != blank
    assign partners_link = settings.wholesale_url | append: '#partners'
  endif
-%}

<header class="site-header" data-site-header>
  <div class="page-width">
    <div class="site-header__shell">
      <div class="site-header__inner">
        <a class="site-header__brand" href="{{ routes.root_url }}">
          {%- if settings.logo -%}
            {{ settings.logo | image_url: width: 280 | image_tag: class: 'site-header__logo', widths: '140, 180, 220, 280', alt: shop.name }}
          {%- else -%}
            <img class="site-header__logo" src="{{ 'raminho-logo.png' | asset_url }}" alt="{{ shop.name }}" width="176" height="57">
          {%- endif -%}
        </a>

        <nav class="site-header__nav" aria-label="Principal">
          <a href="{{ home_link }}">Inicio</a>
          <a href="{{ about_link }}">Sobre</a>
          <a href="{{ catalog_link }}">Catalogo</a>
          <a href="{{ wholesale_link }}">Atacado</a>
          <a href="{{ retail_link }}">Varejo</a>
          <a href="{{ partners_link }}">Parceiros</a>
        </nav>

        <div class="site-header__actions">
          <button class="site-header__action site-header__cart" type="button" data-cart-trigger>
            <span class="site-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
            <span class="site-header__cart-label">Carrinho</span>
          </button>
          <a class="button site-header__cta" href="{{ contact_link }}">Fale Conosco</a>
          <details class="site-header__mobile">
            <summary>Menu</summary>
            <div class="site-header__mobile-panel">
              <a href="{{ home_link }}">Inicio</a>
              <a href="{{ about_link }}">Sobre</a>
              <a href="{{ catalog_link }}">Catalogo</a>
              <a href="{{ wholesale_link }}">Atacado</a>
              <a href="{{ retail_link }}">Varejo</a>
              <a href="{{ partners_link }}">Parceiros</a>
              <a href="{{ routes.search_url }}?type=product&q=">Buscar</a>
              <a href="{{ contact_link }}">Fale Conosco</a>
              <button class="site-header__mobile-link" type="button" data-cart-trigger>
                Carrinho (<span data-cart-count>{{ cart.item_count }}</span>)
              </button>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Cabecalho",
  "settings": []
}
{% endschema %}
