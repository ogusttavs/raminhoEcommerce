<section class="section-block">
  <div class="page-width story-panels">
    {%- for block in section.blocks -%}
      {%- assign fallback_asset = '' -%}
      {%- case forloop.index -%}
        {%- when 1 -%}
          {%- assign fallback_asset = 'raminho-hero-frutas.jpg' -%}
        {%- when 2 -%}
          {%- assign fallback_asset = 'raminho-vitrine-rambutan.jpg' -%}
        {%- when 3 -%}
          {%- assign fallback_asset = 'raminho-loja-mercadao.jpg' -%}
      {%- endcase -%}
      <article class="story-panel reveal" {{ block.shopify_attributes }}>
        <div class="story-panel__copy">
          <p class="section-eyebrow">{{ block.settings.eyebrow }}</p>
          <h2>{{ block.settings.heading }}</h2>
          <p>{{ block.settings.text }}</p>
          {%- if block.settings.button_label != blank -%}
            <a class="button button--ghost" href="{{ block.settings.button_link | default: '/collections/all' }}">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>
        <div class="story-panel__visual">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'story-panel__image', widths: '480, 720, 960, 1200', loading: 'lazy', alt: block.settings.heading }}
          {%- elsif fallback_asset != blank -%}
            {%- if fallback_asset == 'raminho-loja-mercadao.jpg' -%}
              <img class="story-panel__image" src="{{ fallback_asset | asset_url }}" alt="{{ block.settings.heading }}" width="998" height="663">
            {%- else -%}
              <img class="story-panel__image" src="{{ fallback_asset | asset_url }}" alt="{{ block.settings.heading }}" width="2400" height="1350">
            {%- endif -%}
          {%- else -%}
            <img class="story-panel__image" src="{{ 'raminho-hero-frutas.jpg' | asset_url }}" alt="{{ block.settings.heading }}" width="2400" height="1350">
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Paineis editoriais",
  "blocks": [
    {
      "type": "panel",
      "name": "Painel",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Storytelling"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Titulo",
          "default": "A fruta vira protagonista."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Cada modulo combina narrativa de marca com um gatilho comercial claro, valorizando produto, contexto e desejo de compra."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Botao",
          "default": "Ver mais"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Paineis editoriais",
      "blocks": [
        {
          "type": "panel"
        },
        {
          "type": "panel"
        },
        {
          "type": "panel"
        }
      ]
    }
  ]
}
{% endschema %}
