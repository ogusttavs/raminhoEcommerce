{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign origin = product.metafields.custom.origem.value | default: 'Curadoria Raminho'
  assign harvest = product.metafields.custom.safra.value | default: 'Selecao do dia'
  assign storage = product.metafields.custom.conservacao.value | default: 'Armazenamento orientado para preservar textura e sabor.'
  assign delivery = product.metafields.custom.tempo_de_entrega.value | default: 'Entrega planejada na Grande SP.'
  assign related_collection = product.collections | first
-%}

<section class="product-page">
  <div class="page-width product-page__grid">
    <div class="product-gallery reveal">
      <div class="product-gallery__stage">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media -%}
            <div class="product-gallery__slide {% if forloop.first %}is-active{% endif %}" data-media-slide data-media-id="{{ media.id }}">
              {%- if media.media_type == 'image' -%}
                {{ media | image_url: width: 1600 | image_tag: class: 'product-gallery__image', widths: '480, 720, 960, 1280, 1600', loading: 'lazy', alt: media.alt | default: product.title }}
              {%- else -%}
                {{ media | media_tag: class: 'product-gallery__image', image_size: '1200x' }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="product-gallery__slide is-active">
            <img class="product-gallery__image" src="{{ 'raminho-hero-frutas.jpg' | asset_url }}" alt="{{ product.title }}" width="2400" height="1350">
          </div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for media in product.media -%}
            <button class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}" type="button" data-media-thumb data-media-id="{{ media.id }}">
              {{ media.preview_image | image_url: width: 220 | image_tag: widths: '80, 120, 160, 220', loading: 'lazy', alt: media.alt | default: product.title }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product-summary reveal">
      <p class="section-eyebrow">{{ product.vendor | default: shop.name }}</p>
      <h1>{{ product.title }}</h1>
      {%- if product.type != blank -%}
        <p class="product-summary__type">{{ product.type }}</p>
      {%- endif -%}

      <div class="product-summary__price" data-product-price-wrap>
        {% render 'price', product: product, use_variant: true %}
      </div>

      <p class="product-summary__lead">
        {{ product.description | strip_html | truncate: 190 }}
      </p>

      {%- if product.tags.size > 0 -%}
        <div class="chip-row">
          {%- for tag in product.tags limit: 5 -%}
            <span class="chip">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- form 'product', product, class: 'product-form', data-product-form: '' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

        {%- unless product.has_only_default_variant -%}
          <div class="product-options">
            {%- for option in product.options_with_values -%}
              <fieldset class="product-option">
                <legend>{{ option.name }}</legend>
                <div class="option-pills">
                  {%- for value in option.values -%}
                    {%- assign input_id = section.id | append: '-' | append: option.position | append: '-' | append: forloop.index -%}
                    <input
                      class="option-pills__input"
                      type="radio"
                      id="{{ input_id }}"
                      name="option-{{ option.position }}"
                      value="{{ value | escape }}"
                      data-option-input
                      data-option-position="{{ option.position }}"
                      {% if option.selected_value == value %}checked{% endif %}
                    >
                    <label class="option-pills__label" for="{{ input_id }}">{{ value }}</label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="product-form__row">
          <div class="quantity-picker">
            <button type="button" data-qty-button="-1">-</button>
            <input type="number" name="quantity" min="1" value="1" data-qty-input>
            <button type="button" data-qty-button="1">+</button>
          </div>

          <button class="button button--wide" type="submit" data-add-to-cart {% unless current_variant.available %}disabled{% endunless %}>
            {% if current_variant.available %}Adicionar ao carrinho{% else %}Indisponivel{% endif %}
          </button>
        </div>

        <p class="product-form__availability" data-product-status>
          {% if current_variant.available %}Disponivel para entrega programada.{% else %}Produto indisponivel no momento.{% endif %}
        </p>
      {%- endform -%}

      <div class="product-usp-grid">
        <article>
          <span>Origem</span>
          <h2>{{ origin }}</h2>
          <p>Prova de procedencia e selecao consistente para sustentar ticket e confianca.</p>
        </article>
        <article>
          <span>Safra</span>
          <h2>{{ harvest }}</h2>
          <p>Comunicacao pensada para fruta viva: mais contexto, menos grade generica.</p>
        </article>
        <article>
          <span>Conservacao</span>
          <h2>Cuidado</h2>
          <p>{{ storage }}</p>
        </article>
        <article>
          <span>Entrega</span>
          <h2>Grande SP</h2>
          <p>{{ delivery }}</p>
        </article>
      </div>
    </div>
  </div>

  <div class="page-width product-page__details">
    <div class="product-detail-card reveal">
      <p class="section-eyebrow">Descricao</p>
      <div class="rte">
        {{ product.description }}
      </div>
    </div>

    {%- if related_collection != blank and related_collection.products_count > 1 -%}
      <div class="product-detail-card reveal">
        <div class="section-heading section-heading--split">
          <div>
            <p class="section-eyebrow">Continue navegando</p>
            <h2>Mais da colecao {{ related_collection.title }}</h2>
          </div>
          <a class="text-link" href="{{ related_collection.url }}">Ver tudo</a>
        </div>
        <div class="product-grid product-grid--compact">
          {%- for related_product in related_collection.products limit: 4 -%}
            {%- unless related_product.id == product.id -%}
              {% render 'product-card', card_product: related_product %}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <script type="application/json" data-product-variants>
    {{ product.variants | json }}
  </script>
</section>

{% schema %}
{
  "name": "Produto principal",
  "settings": []
}
{% endschema %}
