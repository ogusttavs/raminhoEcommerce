{%- assign hero_image = section.settings.image -%}
<section id="home" class="hero-fruit">
  <div class="hero-fruit__backdrop" aria-hidden="true">
    {%- if hero_image != blank -%}
      {{ hero_image | image_url: width: 1800 | image_tag: class: 'hero-fruit__backdrop-image', widths: '640, 900, 1200, 1600, 1800', loading: 'eager', alt: '' }}
    {%- else -%}
      <img class="hero-fruit__backdrop-image" src="{{ 'raminho-hero-frutas.jpg' | asset_url }}" alt="" width="2400" height="1350">
    {%- endif -%}
  </div>

  <div class="page-width hero-fruit__grid">
    <div class="hero-fruit__content reveal">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <div class="hero-fruit__copy rte">
        {{ section.settings.text }}
      </div>

      <div class="hero-fruit__actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="button button--purchase" href="{{ section.settings.primary_link | default: '/collections/frutas' }}">{{ section.settings.primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="button button--ghost" href="{{ section.settings.secondary_link | default: settings.wholesale_url | default: 'https://raminhoimportadora.com.br/' }}">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>

      <div class="hero-fruit__metrics">
        <div class="metric-card">
          <span>{{ section.settings.metric_1_value }}</span>
          <p>{{ section.settings.metric_1_label }}</p>
        </div>
        <div class="metric-card">
          <span>{{ section.settings.metric_2_value }}</span>
          <p>{{ section.settings.metric_2_label }}</p>
        </div>
        <div class="metric-card">
          <span>{{ section.settings.metric_3_value }}</span>
          <p>{{ section.settings.metric_3_label }}</p>
        </div>
      </div>
    </div>

    <div class="hero-fruit__visual reveal">
      <div class="hero-fruit__glass">
        <p class="hero-fruit__glass-eyebrow">O melhor da natureza</p>
        <h2>Qualidade que se reconhece.</h2>
        <p>Selecao, frescor e origem para comprar com mais seguranca.</p>
      </div>
      <div class="hero-fruit__floating-card">
        <span>Curadoria Raminho</span>
        <p>Mais de 40 anos de experiencia para levar constancia e tranquilidade a cada pedido.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero cinematografico",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "O melhor da natureza"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "A curadoria da Raminho na sua casa."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Frutas, legumes e presentes escolhidos com rigor para quem valoriza qualidade, frescor e confianca.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Botao principal",
      "default": "Explorar frutas"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Link principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Botao secundario",
      "default": "Atacado"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Link secundario"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem"
    },
    {
      "type": "text",
      "id": "metric_1_value",
      "label": "Metrica 1 valor",
      "default": "40+"
    },
    {
      "type": "text",
      "id": "metric_1_label",
      "label": "Metrica 1 legenda",
      "default": "anos de tradicao"
    },
    {
      "type": "text",
      "id": "metric_2_value",
      "label": "Metrica 2 valor",
      "default": "SP"
    },
    {
      "type": "text",
      "id": "metric_2_label",
      "label": "Metrica 2 legenda",
      "default": "entrega focada na Grande Sao Paulo"
    },
    {
      "type": "text",
      "id": "metric_3_value",
      "label": "Metrica 3 valor",
      "default": "Curadoria"
    },
    {
      "type": "text",
      "id": "metric_3_label",
      "label": "Metrica 3 legenda",
      "default": "criterio de selecao em cada pedido"
    }
  ],
  "presets": [
    {
      "name": "Hero cinematografico"
    }
  ]
}
{% endschema %}
