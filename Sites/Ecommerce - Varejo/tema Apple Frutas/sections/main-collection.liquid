{%- liquid
  assign current_sort = collection.sort_by | default: collection.default_sort_by
  assign is_catalog = false
  if collection.handle == 'all'
    assign is_catalog = true
  endif
-%}

<section class="collection-page" {% if is_catalog %}id="catalogo-completo"{% endif %}>
  <div class="page-width">
    <div class="collection-hero reveal">
      <div class="collection-hero__copy">
        <p class="section-eyebrow">{% if is_catalog %}Catalogo completo{% else %}Colecao{% endif %}</p>
        <h1>{% if is_catalog %}Todos os produtos da Raminho{% else %}{{ collection.title }}{% endif %}</h1>
        <div class="rte">
          {%- if is_catalog -%}
            <p>Encontre toda a selecao da Raminho em um so lugar, com navegacao clara, ordenacao simples e foco total nos produtos.</p>
          {%- elsif collection.description != blank -%}
            {{ collection.description }}
          {%- else -%}
            <p>Produtos apresentados com a mesma disciplina visual da marca: espacamento generoso, foco em textura, cor e percepcao de qualidade.</p>
          {%- endif -%}
        </div>
      </div>

      <div class="collection-hero__meta">
        <span>{{ collection.products_count }} itens</span>
        {%- if is_catalog -%}
          <a class="text-link" href="{{ routes.search_url }}?type=product&q=">Buscar no catalogo</a>
        {%- endif -%}
        <form method="get" class="collection-sort">
          <label for="SortBy">Ordenar</label>
          <select id="SortBy" name="sort_by" onchange="this.form.submit()">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == current_sort %}selected{% endif %}>{{ option.name }}</option>
            {%- endfor -%}
          </select>
        </form>
      </div>
    </div>

    {%- paginate collection.products by 24 -%}
      {%- if collection.products_count > 0 -%}
        <div class="product-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', card_product: product %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Paginacao">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}">Anterior</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="{% if part.title == paginate.current_page %}is-current{% endif %}">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}">Proxima</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="empty-state reveal">
          <h2>Nenhum produto encontrado nesta colecao.</h2>
          <p>Use outra categoria ou volte para a home para explorar a curadoria completa.</p>
          <a class="button" href="{{ routes.root_url }}">Voltar para a home</a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Colecao principal",
  "settings": []
}
{% endschema %}
