{%- liquid
  assign featured_image = card_product.featured_media | default: card_product.featured_image
  assign secondary_image = card_product.images[1]
  assign first_variant = card_product.selected_or_first_available_variant
-%}

<article class="product-card reveal">
  <a class="product-card__media" href="{{ card_product.url }}">
    {%- if featured_image -%}
      {{ featured_image | image_url: width: 900 | image_tag: class: 'product-card__image product-card__image--primary', loading: 'lazy', widths: '320, 480, 720, 900', alt: featured_image.alt | default: card_product.title }}
    {%- else -%}
      <div class="product-card__placeholder">Selecao do dia</div>
    {%- endif -%}
    {%- if secondary_image -%}
      {{ secondary_image | image_url: width: 900 | image_tag: class: 'product-card__image product-card__image--secondary', loading: 'lazy', widths: '320, 480, 720, 900', alt: secondary_image.alt | default: card_product.title }}
    {%- endif -%}

    <div class="product-card__badges">
      {%- if card_product.available -%}
        <span class="badge">Fresco</span>
      {%- else -%}
        <span class="badge badge--muted">Esgotado</span>
      {%- endif -%}
      {%- if card_product.tags contains 'premium' -%}
        <span class="badge badge--accent">Premium</span>
      {%- endif -%}
      <span class="badge badge--soft{% if first_variant == blank or first_variant.title == 'Default Title' %} is-hidden{% endif %}" data-card-variant-badge>
        {%- if first_variant and first_variant.title != 'Default Title' -%}{{ first_variant.title | split: '/' | first | strip }}{%- endif -%}
      </span>
    </div>
  </a>

  <div class="product-card__content">
    <div class="product-card__meta">
      <p class="product-card__eyebrow">{{ card_product.vendor | default: shop.name }}</p>
      <h3 class="product-card__title">
        <a href="{{ card_product.url }}">{{ card_product.title }}</a>
      </h3>
      {%- if card_product.type != blank -%}
        <p class="product-card__type">{{ card_product.type }}</p>
      {%- endif -%}
    </div>

    <form class="product-card__quick-add" action="{{ routes.cart_add_url }}" method="post" data-card-product-form>
      <input type="hidden" name="id" value="{{ first_variant.id }}" data-card-variant-id>

      <div class="product-card__purchase-controls">
        <div class="quantity-picker quantity-picker--measure quantity-picker--card">
          <button type="button" aria-label="Diminuir quantidade" data-qty-button="-1">-</button>
          <span class="quantity-picker__display" data-qty-display aria-live="polite">
            {%- if first_variant and first_variant.title != 'Default Title' -%}
              {{ first_variant.title | split: '/' | first | strip }}
            {%- else -%}
              1 un
            {%- endif -%}
          </span>
          <input type="hidden" name="quantity" min="1" value="1" data-qty-input>
          <button type="button" aria-label="Aumentar quantidade" data-qty-button="1">+</button>
        </div>

        <button class="button button--purchase" type="submit" data-card-add-to-cart {% unless card_product.available %}disabled{% endunless %}>
          {% if card_product.available and first_variant %}Comprar por {{ first_variant.price | money }}{% else %}Indisponivel{% endif %}
        </button>
      </div>

      <p class="product-card__status" data-card-status>
        {% if card_product.available %}Use + e - para ajustar a quantidade.{% else %}Produto indisponivel no momento.{% endif %}
      </p>

      <script type="application/json" data-card-variants>
        {{ card_product.variants | json }}
      </script>
    </form>
  </div>
</article>
