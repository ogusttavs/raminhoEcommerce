<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_brand }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="icon" type="image/png" href="{{ 'favicon-ecommerce-varejo.png' | asset_url }}">
    <link rel="apple-touch-icon" href="{{ 'favicon-ecommerce-varejo.png' | asset_url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <title>
      {{ page_title }}
      {%- if current_tags %} · {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} · Página {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} · {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'css-variables' %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
    {% render 'checkout-provider' %}
  </head>
  <body class="theme-premium template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">Pular para o conteúdo</a>

    {% section 'header' %}

    <main id="MainContent" class="site-main" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
    {% render 'cart-drawer' %}
    <div class="floating-actions" aria-label="Acoes rapidas">
      <a class="floating-actions__button" href="#MainContent" aria-label="Voltar ao topo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 6 0 12"></path>
          <path d="m7 11 5-5 5 5"></path>
        </svg>
      </a>
      <a class="floating-actions__button floating-actions__button--whatsapp" href="#" aria-label="Chamar no WhatsApp">
        <svg width="22" height="22" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M19.1 17.5c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1s-.8.9-1 1.1c-.2.2-.4.2-.7.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.7-1.7-2-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.9 1.3 3.1c.2.2 2.2 3.4 5.4 4.8.8.3 1.4.5 1.9.6.8.2 1.6.2 2.2.1.7-.1 1.7-.7 2-1.4.2-.7.2-1.2.1-1.4-.1-.2-.3-.2-.6-.4Z"></path>
          <path d="M16 3.2c-7 0-12.8 5.7-12.8 12.8 0 2.2.6 4.4 1.7 6.2L3.2 28.8l6.8-1.7c1.8 1 3.8 1.6 6 1.6 7 0 12.8-5.7 12.8-12.8S23 3.2 16 3.2Zm0 23.2c-1.9 0-3.7-.5-5.3-1.5l-.4-.2-4 .9.9-3.9-.3-.4c-1-1.6-1.6-3.5-1.6-5.4 0-5.9 4.8-10.7 10.7-10.7S26.7 10 26.7 16 21.9 26.4 16 26.4Z"></path>
        </svg>
      </a>
    </div>

    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
