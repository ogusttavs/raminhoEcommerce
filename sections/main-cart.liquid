{% liquid
  assign minimum_order_amount = settings.minimum_order_value | default: '129.90' | replace: ',', '.' | plus: 0
  assign minimum_order_cents = minimum_order_amount | times: 100
  assign free_shipping_cents = settings.free_shipping_threshold | default: 497 | times: 100
  assign minimum_remaining = minimum_order_cents | minus: cart.total_price
  assign shipping_remaining = free_shipping_cents | minus: cart.total_price
  assign minimum_progress = cart.total_price | times: 100.0 | divided_by: minimum_order_cents
  assign shipping_progress = cart.total_price | times: 100.0 | divided_by: free_shipping_cents
%}

<section class="section">
  <div class="container">
    <div class="collection-header">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="template-title section-heading">{{ section.settings.title }}</h1>
      <p class="section-copy">{{ section.settings.copy }}</p>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-page-form">
        <div class="cart-template__grid">
          <div class="cart-lines">
            {% for item in cart.items %}
              <article class="cart-line">
                <div class="cart-line__layout">
                  <a class="cart-line__media" href="{{ item.url }}">
                    {% if item.image != blank %}
                      {{ item.image | image_url: width: 300 | image_tag: widths: '120, 180, 300', alt: item.product.title, loading: 'lazy' }}
                    {% endif %}
                  </a>

                  <div class="cart-line__meta">
                    <div class="stack" style="gap: 0.75rem;">
                      <h2 class="cart-line__title"><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                      {% if item.variant.title != 'Default Title' %}
                        <div class="cart-note">{{ item.variant.title }}</div>
                      {% endif %}
                      {% for property in item.properties %}
                        {% assign property_first_char = property.first | slice: 0 %}
                        {% if property.last != blank and property_first_char != '_' %}
                          <div class="cart-note">{{ property.first }}: {{ property.last }}</div>
                        {% endif %}
                      {% endfor %}
                      <div class="cart-line__price-row">
                        <strong>{{ item.final_line_price | money }}</strong>
                        {% if item.original_line_price > item.final_line_price %}
                          <span class="price-compare">{{ item.original_line_price | money }}</span>
                        {% endif %}
                      </div>
                    </div>

                    <div class="cart-form-actions">
                      <label class="visually-hidden" for="Quantity-{{ item.key }}">Quantidade</label>
                      <input
                        id="Quantity-{{ item.key }}"
                        class="cart-qty-input"
                        type="number"
                        min="0"
                        name="updates[]"
                        value="{{ item.quantity }}"
                      >
                      <a class="button button--outline" href="{{ item.url }}">Editar produto</a>
                    </div>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>

          <aside class="cart-summary">
            <div class="summary-card">
              <h2 class="summary-card__title">Resumo do pedido</h2>

              <div class="summary-meta">
                <span>Subtotal</span>
                <strong>{{ cart.total_price | money }}</strong>
              </div>

              <div class="stack">
                <div class="cart-note">
                  {% if minimum_remaining > 0 %}
                    Faltam {{ minimum_remaining | money }} para atingir o pedido mínimo.
                  {% else %}
                    Pedido mínimo atingido.
                  {% endif %}
                </div>
                <div class="progress-meter">
                  <div class="progress-meter__bar" style="width:{% if minimum_progress > 100 %}100{% elsif minimum_progress < 0 %}0{% else %}{{ minimum_progress }}{% endif %}%"></div>
                </div>
              </div>

              <div class="stack">
                <div class="cart-note">
                  {% if shipping_remaining > 0 %}
                    Faltam {{ shipping_remaining | money }} para liberar a entrega da Raminho.
                  {% else %}
                    Entrega da Raminho liberada.
                  {% endif %}
                </div>
                <div class="progress-meter">
                  <div class="progress-meter__bar" style="width:{% if shipping_progress > 100 %}100{% elsif shipping_progress < 0 %}0{% else %}{{ shipping_progress }}{% endif %}%"></div>
                </div>
              </div>
            </div>

            <div class="cart-summary__actions">
              <button class="button button--outline button--block" type="submit" name="update">Atualizar carrinho</button>
              <button class="button button--secondary button--block" type="submit" name="checkout">Finalizar com checkout transparente</button>
            </div>
          </aside>
        </div>
      </form>
    {% else %}
      <div class="template-empty">
        <h2 class="section-heading" style="font-size: 2rem;">Seu carrinho está vazio</h2>
        <p class="section-copy">Escolha os produtos que deseja receber e volte aqui para revisar a sua selecao.</p>
        <a class="button button--secondary" href="{{ routes.all_products_collection_url }}">Explorar catálogo</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Carrinho principal",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sua selecao"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Seu carrinho"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Texto",
      "default": "Revise os itens escolhidos com clareza antes de seguir para o checkout."
    }
  ]
}
{% endschema %}
