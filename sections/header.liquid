<header class="site-header" data-site-header>
  {% if section.settings.announcement_text != blank %}
    <div class="site-announcement">
      <div class="container site-announcement__inner">
        <span>{{ section.settings.announcement_text }}</span>
      </div>
    </div>
  {% endif %}

  <div class="container site-header__row">
    <div class="site-header__brand">
      <button class="header-icon mobile-only" type="button" aria-label="Abrir menu" data-drawer-toggle="menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>

      <a class="site-header__logo" href="{{ routes.root_url }}">
        {% if settings.brand_logo != blank %}
          <img src="{{ 'logo-lp-atacado.png' | asset_url }}" alt="{{ shop.name }}" width="400" height="120" loading="eager" class="logo-landing">
          {{ settings.brand_logo | image_url: width: 520 | image_tag: widths: '260, 360, 520', alt: shop.name, loading: 'eager', class: 'logo-dark' }}
          {% if settings.brand_logo_inverted != blank %}
            {{ settings.brand_logo_inverted | image_url: width: 520 | image_tag: widths: '260, 360, 520', alt: shop.name, loading: 'eager', class: 'logo-light' }}
          {% else %}
            <img src="{{ 'logo-ecommerce-varejo-light.png' | asset_url }}" alt="{{ shop.name }}" width="520" height="520" loading="eager" class="logo-light">
          {% endif %}
        {% else %}
          <img src="{{ 'logo-lp-atacado.png' | asset_url }}" alt="{{ shop.name }}" width="400" height="120" loading="eager" class="logo-landing">
          <img src="{{ 'logo-ecommerce-varejo-transparent.png' | asset_url }}" alt="{{ shop.name }}" width="520" height="520" loading="eager" class="logo-dark">
          <img src="{{ 'logo-ecommerce-varejo-light.png' | asset_url }}" alt="{{ shop.name }}" width="520" height="520" loading="eager" class="logo-light">
        {% endif %}
      </a>
    </div>

    <nav class="site-header__nav" aria-label="Navegação principal">
      <ul class="site-header__nav-list">
        {% if section.settings.primary_menu != blank and section.settings.primary_menu.links.size > 0 %}
          {% for link in section.settings.primary_menu.links %}
            <li>
              <a href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        {% else %}
          <li><a href="{{ routes.all_products_collection_url }}">Catálogo</a></li>
          <li><a href="{{ routes.search_url }}">Buscar</a></li>
          <li><a href="#historia">História</a></li>
        {% endif %}
      </ul>
    </nav>

    <div class="site-header__actions">
      <button class="header-icon desktop-only" type="button" aria-label="Buscar" data-drawer-toggle="search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
      </button>

      <button class="button button--secondary header-cart-button desktop-only" type="button" data-cart-open>
        <span>Seu carrinho</span>
        <span class="header-cart-button__count{% if cart.item_count == 0 %} is-empty{% endif %}" data-cart-count>
          {{ cart.item_count }}
        </span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M5 12h14"></path>
          <path d="m13 6 6 6-6 6"></path>
        </svg>
      </button>

      {% if section.settings.show_account_link %}
        <a class="header-icon mobile-only" href="{{ routes.account_url }}" aria-label="Minha conta">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="8" r="4"></circle>
            <path d="M5 20c1.6-3.2 4-4.8 7-4.8S17.4 16.8 19 20"></path>
          </svg>
        </a>
      {% endif %}

      <button class="header-icon mobile-only" type="button" aria-label="Abrir carrinho" data-cart-open>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M6 7h12l-1.1 10.2a2 2 0 0 1-2 1.8H9.1a2 2 0 0 1-2-1.8L6 7Z"></path>
          <path d="M9 7V5a3 3 0 0 1 6 0v2"></path>
        </svg>
        <span class="cart-count{% if cart.item_count == 0 %} is-hidden{% endif %}" data-cart-count>
          {{ cart.item_count }}
        </span>
      </button>
    </div>
  </div>

  <div class="drawer drawer--left" data-drawer="menu">
    <button class="drawer__backdrop" type="button" aria-label="Fechar menu" data-drawer-close></button>
    <div class="drawer__panel">
      <div class="drawer-head">
        <h2 class="drawer-title">Explorar</h2>
        <button class="drawer-close" type="button" aria-label="Fechar menu" data-drawer-close>
          ×
        </button>
      </div>

      <nav class="drawer-nav" aria-label="Menu mobile">
        <ul class="drawer-nav__list">
          {% if section.settings.primary_menu != blank and section.settings.primary_menu.links.size > 0 %}
            {% for link in section.settings.primary_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="{{ routes.all_products_collection_url }}">Catálogo</a></li>
            <li><a href="{{ routes.search_url }}">Buscar</a></li>
            <li><a href="#historia">História</a></li>
          {% endif %}
          {% if section.settings.secondary_menu != blank and section.settings.secondary_menu.links.size > 0 %}
            {% for link in section.settings.secondary_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          {% endif %}
        </ul>
      </nav>

      <div class="drawer-meta">
        <p class="meta-copy">{{ section.settings.menu_note }}</p>
      </div>
    </div>
  </div>

  <div class="drawer" data-drawer="search">
    <button class="drawer__backdrop" type="button" aria-label="Fechar busca" data-drawer-close></button>
    <div class="drawer__panel">
      <div class="drawer-head">
        <h2 class="drawer-title">Buscar no catálogo</h2>
        <button class="drawer-close" type="button" aria-label="Fechar busca" data-drawer-close>
          ×
        </button>
      </div>

      <div class="search-panel">
        <form action="{{ routes.search_url }}" method="get" role="search" class="drawer-search">
          <input class="search-input" type="search" name="q" placeholder="Ex.: cerejas, uvas sem semente, frutas da estação" value="{{ search.terms | escape }}">
          <input type="hidden" name="type" value="product">
          <button class="button button--secondary button--block" type="submit">Buscar agora</button>
        </form>

        {% if section.settings.search_note != blank %}
          <p class="meta-copy">{{ section.settings.search_note }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header premium",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Mensagem superior",
      "default": "O melhor da natureza, com entrega cuidadosa em toda a Grande Sao Paulo"
    },
    {
      "type": "link_list",
      "id": "primary_menu",
      "label": "Menu principal"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Menu secundario"
    },
    {
      "type": "checkbox",
      "id": "show_account_link",
      "label": "Mostrar link de conta",
      "default": true
    },
    {
      "type": "textarea",
      "id": "search_note",
      "label": "Texto de apoio da busca",
      "default": "Busque por frutas, selecoes especiais, presentes ou itens da estacao."
    },
    {
      "type": "textarea",
      "id": "menu_note",
      "label": "Texto de apoio do menu",
      "default": "Escolha com calma. O catalogo foi pensado para uma navegacao simples, clara e elegante."
    }
  ]
}
{% endschema %}
